---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteSettings } from '../lib/sanity';

const settings = await getSiteSettings();
const waNumber = settings?.whatsapp ?? '447446508333';
---

<BaseLayout
  title={`Contact — ${settings?.businessName ?? 'Getwebify'}`}
  description="Get in touch with Getwebify. Tell us about your project and we'll get back to you within one business day."
>
  <section class="py-20 md:py-32 px-6 md:px-10 max-w-[1200px] mx-auto">
    <h1
      class="font-display text-4xl md:text-6xl mb-6"
      style="font-size: clamp(2rem, 6vw, 4rem); font-variation-settings: 'opsz' 144"
    >
      Let's talk about your <em style="font-style: italic">project.</em>
    </h1>
    <hr class="border-rule mb-12" />

    <div class="grid md:grid-cols-2 gap-16">
      <form method="POST" action="/api/contact" class="space-y-6 font-body" aria-label="Contact form">
        <!-- Honeypot — hidden from real users, bots fill it -->
        <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="name" class="block text-xs uppercase tracking-widest text-muted mb-2">Full Name *</label>
            <input id="name" name="name" type="text" required class="w-full border border-rule bg-transparent px-4 py-3 text-ink focus:border-terracotta outline-none transition-colors" />
          </div>
          <div>
            <label for="business" class="block text-xs uppercase tracking-widest text-muted mb-2">Business Name</label>
            <input id="business" name="business" type="text" class="w-full border border-rule bg-transparent px-4 py-3 text-ink focus:border-terracotta outline-none transition-colors" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="email" class="block text-xs uppercase tracking-widest text-muted mb-2">Email *</label>
            <input id="email" name="email" type="email" required class="w-full border border-rule bg-transparent px-4 py-3 text-ink focus:border-terracotta outline-none transition-colors" />
          </div>
          <div>
            <label for="phone" class="block text-xs uppercase tracking-widest text-muted mb-2">Phone / WhatsApp</label>
            <input id="phone" name="phone" type="tel" class="w-full border border-rule bg-transparent px-4 py-3 text-ink focus:border-terracotta outline-none transition-colors" />
          </div>
        </div>

        <div>
          <label for="projectType" class="block text-xs uppercase tracking-widest text-muted mb-2">Project Type *</label>
          <select id="projectType" name="projectType" required class="w-full border border-rule bg-cream px-4 py-3 text-ink focus:border-terracotta outline-none transition-colors appearance-none">
            <option value="" disabled selected>Select one…</option>
            <option value="New website">New website</option>
            <option value="Redesign">Redesign</option>
            <option value="SEO">SEO</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-xs uppercase tracking-widest text-muted mb-2">Message *</label>
          <textarea id="message" name="message" required rows="5" class="w-full border border-rule bg-transparent px-4 py-3 text-ink focus:border-terracotta outline-none transition-colors resize-none"></textarea>
        </div>

        <!-- Cloudflare Turnstile widget (Phase 4) -->
        <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}></div>

        <div class="flex items-start gap-3">
          <input id="gdpr" name="gdpr" type="checkbox" required class="mt-1 accent-terracotta" />
          <label for="gdpr" class="text-sm text-muted">
            I agree to be contacted by Getwebify about my enquiry. We won't share your data or send marketing without permission.
          </label>
        </div>

        <button type="submit" class="bg-terracotta text-cream font-medium px-8 py-4 rounded-full hover:-translate-y-0.5 transition-all w-full md:w-auto">
          Send message →
        </button>
      </form>

      <aside class="space-y-10 font-body">
        <div>
          <p class="text-xs uppercase tracking-widest text-muted mb-3">WhatsApp</p>
          <a href={`https://wa.me/${waNumber}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-ink hover:text-terracotta transition-colors">
            <span class="w-2 h-2 rounded-full bg-green-500 wa-dot inline-block"></span>
            Message us on WhatsApp
          </a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-muted mb-3">Email</p>
          <a href={`mailto:${settings?.email ?? 'hello@getwebify.uk'}`} class="text-ink hover:text-terracotta transition-colors nav-link">
            {settings?.email ?? 'hello@getwebify.uk'}
          </a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-muted mb-3">Response time</p>
          <p class="text-ink">Within one business day</p>
        </div>
        <hr class="border-rule" />
        <p class="text-muted text-sm leading-relaxed">
          Not ready to fill in a form? Message us on WhatsApp — it's the fastest way to get a response.
        </p>
      </aside>
    </div>
  </section>

  <!-- Turnstile script (Phase 4 will wire up properly) -->
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</BaseLayout>
