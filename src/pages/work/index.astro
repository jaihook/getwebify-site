---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCaseStudies } from '../../lib/sanity';

const studies = await getCaseStudies();
---

<BaseLayout
  title="Our Work — Getwebify"
  description="Case studies and client projects from Getwebify — a UK web agency building high-performance sites with AI-powered tools."
>
  <section class="py-20 md:py-32 px-6 md:px-10 max-w-[1200px] mx-auto">
    <header class="mb-16 max-w-[600px]">
      <p class="font-body text-xs uppercase tracking-widest text-muted mb-4">Our Work</p>
      <h1 class="font-display leading-tight mb-6" style="font-size: clamp(2.5rem, 6vw, 4rem); font-variation-settings: 'opsz' 144">
        Projects that <em>perform</em>
      </h1>
      <p class="font-body text-muted text-lg leading-relaxed">
        Real work for real businesses. Every project is built to generate leads, rank on Google, and grow revenue.
      </p>
    </header>

    {studies.length === 0 ? (
      <div class="border border-rule rounded-lg p-16 text-center">
        <p class="font-display text-2xl mb-4" style="font-variation-settings: 'opsz' 72">Projects launching soon</p>
        <p class="font-body text-muted mb-8">We're documenting our work. In the meantime, let's talk about yours.</p>
        <a
          href="/contact"
          class="bg-terracotta text-cream font-body font-medium px-6 py-3 rounded-full hover:-translate-y-0.5 transition-all inline-block"
        >
          Start a project →
        </a>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 gap-8">
        {studies.map((study: any) => (
          <a
            href={`/work/${study.slug.current}`}
            class="group border border-rule rounded-lg p-8 hover:border-terracotta transition-colors"
          >
            {study.clientAnonymised && (
              <p class="font-body text-xs uppercase tracking-widest text-muted mb-3">{study.clientAnonymised}</p>
            )}
            <h2 class="font-display text-2xl mb-4 group-hover:text-terracotta transition-colors" style="font-variation-settings: 'opsz' 72">
              {study.title}
            </h2>
            {study.result && (
              <p class="font-body text-muted leading-relaxed text-sm">{study.result}</p>
            )}
            <span class="font-body text-terracotta text-sm font-medium mt-6 inline-block">
              Read case study →
            </span>
          </a>
        ))}
      </div>
    )}

    <div class="mt-20 pt-12 border-t border-rule">
      <div class="max-w-[480px]">
        <p class="font-display text-2xl mb-4" style="font-variation-settings: 'opsz' 72">Want to be next?</p>
        <p class="font-body text-muted mb-6">We build fast, professional websites that win clients and rank on Google.</p>
        <a
          href="/contact"
          class="bg-terracotta text-cream font-body font-medium px-6 py-3 rounded-full hover:-translate-y-0.5 transition-all inline-block"
        >
          Get a quote →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
