---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCaseStudies, getCaseStudy } from '../../lib/sanity';

export async function getStaticPaths() {
  const studies = await getCaseStudies();
  return studies.map((s: any) => ({
    params: { slug: s.slug.current },
  }));
}

const { slug } = Astro.params;
const study = await getCaseStudy(slug!);

if (!study) return Astro.redirect('/');
---

<BaseLayout
  title={`${study.title} — Getwebify Work`}
  description={`${study.clientAnonymised ? study.clientAnonymised + ': ' : ''}${study.result ?? study.problem ?? ''}`}
>
  <article class="py-20 md:py-32 px-6 md:px-10 max-w-[800px] mx-auto">
    {study.clientAnonymised && (
      <p class="font-body text-xs uppercase tracking-widest text-muted mb-4">{study.clientAnonymised}</p>
    )}
    <h1 class="font-display text-3xl md:text-5xl mb-6 leading-tight" style="font-size: clamp(1.75rem, 5vw, 3.5rem); font-variation-settings: 'opsz' 144">
      {study.title}
    </h1>
    <hr class="border-rule mb-12" />

    <div class="space-y-12 font-body">
      {study.problem && (
        <div>
          <h2 class="font-display text-xl mb-3" style="font-variation-settings: 'opsz' 72">The challenge</h2>
          <p class="text-muted leading-relaxed">{study.problem}</p>
        </div>
      )}
      {study.solution && (
        <div>
          <h2 class="font-display text-xl mb-3" style="font-variation-settings: 'opsz' 72">What we built</h2>
          <p class="text-muted leading-relaxed">{study.solution}</p>
        </div>
      )}
      {study.result && (
        <div class="bg-ink text-cream px-8 py-8 rounded">
          <h2 class="font-display text-xl mb-3 text-cream" style="font-variation-settings: 'opsz' 72">The result</h2>
          <p class="text-cream/80 leading-relaxed">{study.result}</p>
        </div>
      )}
    </div>

    <div class="mt-16 pt-12 border-t border-rule">
      <p class="font-display text-2xl mb-6" style="font-variation-settings: 'opsz' 72">Want results like this?</p>
      <a href="/contact" class="bg-terracotta text-cream font-body font-medium px-6 py-3 rounded-full hover:-translate-y-0.5 transition-all inline-block">
        Start your project →
      </a>
    </div>
  </article>
</BaseLayout>
