---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReviewCard from '../components/ReviewCard.astro';
import { getReviews } from '../lib/sanity';

const reviews = await getReviews();
const avgRating = reviews.length
  ? (reviews.reduce((s: number, r: any) => s + r.rating, 0) / reviews.length).toFixed(1)
  : null;
---

<BaseLayout
  title="Client Reviews — Getwebify"
  description={`${reviews.length} reviews · ${avgRating ?? 5}★ average — real feedback from UK businesses we've helped.`}
>
  {reviews.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Getwebify",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": avgRating,
        "reviewCount": reviews.length,
        "bestRating": "5",
        "worstRating": "1"
      }
    })} />
  )}

  <section class="py-20 md:py-32 px-6 md:px-10 max-w-[1200px] mx-auto">
    <div class="flex items-baseline gap-6 mb-2 flex-wrap">
      <h1 class="font-display text-4xl md:text-6xl" style="font-size: clamp(2rem, 6vw, 4rem); font-variation-settings: 'opsz' 144">
        Client Reviews
      </h1>
      {avgRating && <span class="font-display text-2xl text-terracotta" style="font-variation-settings: 'opsz' 72">{avgRating}★</span>}
    </div>
    <hr class="border-rule mb-12" />

    {reviews.length === 0 && <p class="font-body text-muted">Reviews coming soon.</p>}

    <div class="columns-1 md:columns-2 gap-8">
      {reviews.map((r: any) => (
        <div class="mb-8">
          <ReviewCard
            clientName={r.clientName}
            rating={r.rating}
            quote={r.quote}
            projectType={r.projectType}
            date={r.date}
          />
        </div>
      ))}
    </div>
  </section>

  <section class="py-16 px-6 md:px-10 max-w-[1200px] mx-auto border-t border-rule">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
      <p class="font-display text-2xl" style="font-variation-settings: 'opsz' 72">Want results like these?</p>
      <a href="/contact" class="bg-terracotta text-cream font-body font-medium px-6 py-3 rounded-full hover:-translate-y-0.5 transition-all self-start">
        Start your project →
      </a>
    </div>
  </section>
</BaseLayout>
