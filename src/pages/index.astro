---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getServices, getPosts, getReviews, getSiteSettings } from '../lib/sanity';

const [services, posts, reviews, settings] = await Promise.all([
  getServices(),
  getPosts(),
  getReviews(),
  getSiteSettings(),
]);

const featuredReviews = reviews.filter((r: any) => r.featured).slice(0, 3);
const latestPosts = posts.slice(0, 3);
---

<BaseLayout
  title={`${settings?.businessName ?? 'Getwebify'} — Websites that win you business`}
  description={settings?.metaDescription}
>
  <!-- Hero -->
  <section class="min-h-screen flex flex-col justify-center px-6 md:px-10 max-w-[1200px] mx-auto">
    <div class="max-w-3xl">
      <h1
        class="font-display text-ink leading-[1.05] mb-8"
        style="font-size: clamp(2.5rem, 8vw, 6rem); font-variation-settings: 'opsz' 144"
      >
        <span class="word block">We build websites</span>
        <span class="word block">that win you</span>
        <em class="word block" style="font-style: italic">business.</em>
      </h1>
      <p class="font-body text-muted text-lg md:text-xl max-w-md mb-10">
        {settings?.tagline ?? 'UK web agency helping small businesses get found, look great, and convert visitors into clients.'}
      </p>
      <div class="flex flex-wrap gap-4 items-center mb-16">
        <a
          href="/contact"
          class="bg-terracotta text-cream font-body font-medium px-6 py-3 rounded-full hover:-translate-y-0.5 transition-all"
        >
          Start a project →
        </a>
        <a
          href={`https://wa.me/${settings?.whatsapp ?? '447446508333'}`}
          target="_blank"
          rel="noopener noreferrer"
          class="font-body text-ink flex items-center gap-2 hover:text-terracotta transition-colors"
        >
          <span class="w-2 h-2 rounded-full bg-green-500 wa-dot inline-block"></span>
          Message on WhatsApp
        </a>
      </div>
      <div class="flex flex-wrap gap-4 text-xs uppercase tracking-widest text-muted font-body">
        <span>50+ UK businesses</span>
        <span aria-hidden="true">·</span>
        <span>Since 2023</span>
        <span aria-hidden="true">·</span>
        <span>Rated 5★</span>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section aria-label="Services" class="py-20 md:py-32 px-6 md:px-10 max-w-[1200px] mx-auto">
    <h2 class="font-display text-3xl md:text-4xl mb-2" style="font-variation-settings: 'opsz' 72">What we do</h2>
    <hr class="border-rule mb-12" />
    <ol class="divide-y divide-rule">
      {services.map((s: any, i: number) => (
        <li class="reveal py-8 flex gap-6 items-start group pl-0 hover:pl-4 hover:border-l-2 hover:border-terracotta transition-all duration-200">
          <span class="font-display text-6xl md:text-8xl text-rule leading-none select-none flex-shrink-0" style="font-variation-settings: 'opsz' 144" aria-hidden="true">
            {String(i + 1).padStart(2, '0')}
          </span>
          <div>
            <h3 class="font-display text-xl md:text-2xl mb-2">{s.title}</h3>
            <p class="font-body text-muted">{s.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- Latest posts -->
  {latestPosts.length > 0 && (
    <section aria-label="Latest posts" class="py-20 md:py-32 px-6 md:px-10 max-w-[1200px] mx-auto">
      <div class="flex items-baseline justify-between mb-2">
        <h2 class="font-display text-3xl md:text-4xl" style="font-variation-settings: 'opsz' 72">Latest thinking</h2>
        <a href="/blog" class="font-body text-sm text-terracotta nav-link">All posts →</a>
      </div>
      <hr class="border-rule mb-12" />
      <div class="grid md:grid-cols-3 gap-8">
        {latestPosts.map((post: any) => (
          <article class="reveal">
            <a href={`/blog/${post.slug.current}`} class="group block">
              {post.hasAffiliates && (
                <span class="inline-block bg-forest text-cream text-xs px-2 py-0.5 rounded mb-2 font-body">Contains affiliate links</span>
              )}
              <h3 class="font-display text-lg group-hover:text-terracotta transition-colors mb-1">{post.title}</h3>
              <p class="font-body text-muted text-sm">{post.excerpt}</p>
            </a>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- Featured reviews -->
  {featuredReviews.length > 0 && (
    <section aria-label="Client reviews" class="py-20 md:py-32 bg-ink text-cream px-6 md:px-10">
      <div class="max-w-[1200px] mx-auto">
        <h2 class="font-display text-3xl md:text-4xl mb-2 text-cream" style="font-variation-settings: 'opsz' 72">What clients say</h2>
        <hr class="border-cream/20 mb-12" />
        <div class="grid md:grid-cols-3 gap-8">
          {featuredReviews.map((r: any) => (
            <blockquote class="reveal">
              <div class="flex gap-0.5 mb-3" aria-label={`${r.rating} out of 5 stars`}>
                {Array.from({ length: r.rating }).map(() => (
                  <svg class="w-4 h-4 fill-terracotta" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                ))}
              </div>
              <p class="font-display italic text-lg mb-4">"{r.quote}"</p>
              <footer class="font-body text-xs uppercase tracking-widest text-cream/60">
                {r.clientName}{r.projectType ? ` — ${r.projectType}` : ''}
              </footer>
            </blockquote>
          ))}
        </div>
        <a href="/reviews" class="inline-block mt-12 font-body text-sm text-cream/70 nav-link">All reviews →</a>
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="py-20 md:py-32 px-6 md:px-10 max-w-[1200px] mx-auto text-center">
    <h2 class="font-display text-3xl md:text-5xl mb-6" style="font-variation-settings: 'opsz' 72">Ready to get started?</h2>
    <p class="font-body text-muted max-w-md mx-auto mb-10">Tell us about your project. We'll get back to you within one business day.</p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/contact" class="bg-terracotta text-cream font-body font-medium px-8 py-4 rounded-full hover:-translate-y-0.5 transition-all">
        Get a free quote →
      </a>
      <a
        href={`https://wa.me/${settings?.whatsapp ?? '447446508333'}`}
        target="_blank"
        rel="noopener noreferrer"
        class="border border-rule font-body font-medium px-8 py-4 rounded-full hover:border-terracotta hover:text-terracotta transition-all"
      >
        WhatsApp us
      </a>
    </div>
  </section>
</BaseLayout>
