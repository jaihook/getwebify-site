---
interface Props {
  headline?: string;
  subline?: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
}
const {
  headline = 'We build websites\nthat win\n*clients.*',
  subline = 'Fast, beautiful, SEO-ready sites for UK businesses. From £1,500.',
  ctaPrimary = { label: 'Start your project', href: '/contact' },
  ctaSecondary = { label: 'See our work', href: '/work' },
} = Astro.props;

const lines = headline.split('\n');
---

<section class="min-h-[90vh] flex items-center pt-16 px-6 md:px-10">
  <div class="max-w-[1200px] mx-auto w-full py-20 md:py-32">
    <div class="max-w-3xl">
      <h1 class="font-display leading-[1.05] mb-8" style="font-size: clamp(2.5rem, 7vw, 5rem); font-variation-settings: 'opsz' 144, 'wght' 400">
        {lines.map((line, i) => {
          const isItalic = line.startsWith('*') && line.endsWith('*');
          const text = isItalic ? line.slice(1, -1) : line;
          return (
            <span class:list={['word block', isItalic && 'italic text-terracotta']}
              style={`animation-delay: ${i * 120}ms`}>
              {text}
            </span>
          );
        })}
      </h1>

      <p class="reveal font-body text-lg md:text-xl text-muted leading-relaxed mb-10 max-w-xl">
        {subline}
      </p>

      <div class="reveal flex flex-wrap gap-4" style="animation-delay: 360ms">
        <a
          href={ctaPrimary.href}
          class="bg-terracotta text-cream font-body font-medium px-7 py-3.5 rounded-full hover:-translate-y-0.5 transition-all text-base"
        >
          {ctaPrimary.label}
        </a>
        <a
          href={ctaSecondary.href}
          class="border border-ink text-ink font-body font-medium px-7 py-3.5 rounded-full hover:bg-ink hover:text-cream transition-all text-base"
        >
          {ctaSecondary.label}
        </a>
      </div>
    </div>
  </div>
</section>
