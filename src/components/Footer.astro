---
const year = new Date().getFullYear();
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
---

<footer class="bg-ink text-cream border-t border-ink">
  <div class="max-w-[1200px] mx-auto px-6 md:px-10 py-16 grid md:grid-cols-3 gap-12">
    <div>
      <a href="/" class="font-display text-2xl font-semibold text-cream hover:text-terracotta transition-colors block mb-3" style="font-variation-settings: 'opsz' 72">
        Getwebify
      </a>
      <p class="font-body text-sm text-cream/60 leading-relaxed max-w-xs">
        UK web agency building fast, beautiful websites that win clients and rank on Google.
      </p>
    </div>

    <div>
      <p class="font-body text-xs uppercase tracking-widest text-cream/40 mb-4">Pages</p>
      <ul class="font-body text-sm space-y-3">
        {[
          ['/work', 'Work'],
          ['/blog', 'Blog'],
          ['/reviews', 'Reviews'],
          ['/tools', 'Tools'],
          ['/about', 'About'],
          ['/contact', 'Contact'],
        ].map(([href, label]) => (
          <li>
            <a href={href} class="text-cream/60 hover:text-cream transition-colors">{label}</a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <p class="font-body text-xs uppercase tracking-widest text-cream/40 mb-4">Get in touch</p>
      <div class="space-y-3 font-body text-sm">
        <a href="https://wa.me/447446508333" target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-2 text-cream/60 hover:text-cream transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.138.563 4.141 1.543 5.874L0 24l6.282-1.512A11.937 11.937 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.814 9.814 0 01-5.003-1.368l-.359-.214-3.728.897.935-3.625-.234-.372A9.817 9.817 0 012.182 12C2.182 6.574 6.574 2.182 12 2.182S21.818 6.574 21.818 12 17.426 21.818 12 21.818z"/>
          </svg>
          WhatsApp us
        </a>
        <a href="mailto:hello@getwebify.uk"
          class="flex items-center gap-2 text-cream/60 hover:text-cream transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m2 7 10 7 10-7"/>
          </svg>
          hello@getwebify.uk
        </a>
      </div>
    </div>
  </div>

  <!-- Newsletter strip -->
  <div class="border-t border-cream/10">
    <div class="max-w-[1200px] mx-auto px-6 md:px-10 py-8 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="shrink-0">
        <p class="font-display text-base text-cream" style="font-variation-settings: 'opsz' 36">Free website tips for UK businesses</p>
        <p class="font-body text-xs text-cream/40 mt-0.5">Practical advice. No fluff. Unsubscribe any time.</p>
      </div>
      <div id="footer-subscribe-wrap" class="flex flex-col gap-2 w-full md:w-auto">
        <form id="footer-subscribe-form" class="flex gap-2 w-full md:w-auto" novalidate>
          <input
            type="email"
            name="email"
            placeholder="your@email.co.uk"
            required
            autocomplete="email"
            class="flex-1 md:w-64 bg-cream/10 border border-cream/20 text-cream placeholder:text-cream/40 px-4 py-2.5 text-sm focus:outline-none focus:border-cream/60 transition-colors rounded font-body"
          />
          <button
            type="submit"
            class="bg-terracotta text-cream font-body font-medium px-5 py-2.5 text-sm rounded hover:-translate-y-0.5 transition-all whitespace-nowrap shrink-0"
          >
            Subscribe →
          </button>
          {TURNSTILE_SITE_KEY && (
            <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-size="invisible" data-theme="dark"></div>
          )}
        </form>
        <p id="footer-subscribe-error" class="hidden font-body text-xs text-red-400">
          Something went wrong — <a href="https://wa.me/447446508333" class="underline">WhatsApp us</a>.
        </p>
      </div>
      <div id="footer-subscribe-success" class="hidden text-center md:text-left">
        <p class="font-display text-cream text-base" style="font-variation-settings: 'opsz' 36">You're in!</p>
        <p class="font-body text-xs text-cream/60 mt-0.5">We'll be in touch with free website tips.</p>
      </div>
    </div>
  </div>

  <div class="border-t border-cream/10">
    <div class="max-w-[1200px] mx-auto px-6 md:px-10 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 font-body text-xs text-cream/40">
      <p>&copy; {year} Getwebify Ltd. All rights reserved.</p>
      <p>Registered in England &amp; Wales</p>
    </div>
  </div>
</footer>

{TURNSTILE_SITE_KEY && (
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<script>
  const form = document.getElementById('footer-subscribe-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const email = (fd.get('email') as string).trim();
      const cfToken = (fd.get('cf-turnstile-response') as string) ?? '';
      const btn = form.querySelector('button') as HTMLButtonElement;
      const wrap = document.getElementById('footer-subscribe-wrap');
      const success = document.getElementById('footer-subscribe-success');
      const errorEl = document.getElementById('footer-subscribe-error');

      btn.disabled = true;
      btn.textContent = '…';

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'footer', 'cf-turnstile-response': cfToken }),
        });
        if (res.ok) {
          wrap?.classList.add('hidden');
          success?.classList.remove('hidden');
        } else {
          errorEl?.classList.remove('hidden');
          btn.disabled = false;
          btn.textContent = 'Subscribe →';
        }
      } catch {
        errorEl?.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'Subscribe →';
      }
    });
  }
</script>
